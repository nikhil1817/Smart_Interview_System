# Copy this file to backend/.env and replace with real values

# --- OpenAI (primary) ---
# Required for LLM-powered interview features
OPENAI_API_KEY=sk-REPLACE_ME
# Models (choose from o4, o4-mini, gpt-4o, gpt-4o-mini, etc.)
OPENAI_QUESTION_MODEL=o4-mini
OPENAI_EVAL_MODEL=o4-mini
OPENAI_FEEDBACK_MODEL=o4-mini
# Tuning
OPENAI_TIMEOUT_SECONDS=25
OPENAI_MAX_RETRIES=1
OPENAI_RETRY_BACKOFF_SECONDS=0.8
OPENAI_CONTEXT_TURNS=6
OPENAI_QUESTION_MAX_TOKENS=420
OPENAI_EVAL_MAX_TOKENS=520
OPENAI_FEEDBACK_MAX_TOKENS=420

# --- Deprecated: GitHub Models (now disabled by default) ---
# Commented out to avoid accidental use. If you want to use
# GitHub Models again, uncomment and configure below.
# GITHUB_MODELS_API_KEY=replace_with_your_github_models_api_key
# GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
# GITHUB_QUESTION_MODEL=openai/o4-mini
# GITHUB_EVAL_MODEL=openai/o4-mini
# GITHUB_FEEDBACK_MODEL=openai/o4-mini
# GITHUB_MODELS_TIMEOUT_SECONDS=25
# GITHUB_MODELS_MAX_RETRIES=2
# GITHUB_MODELS_RETRY_BACKOFF_SECONDS=0.8
# GITHUB_MODELS_CONTEXT_TURNS=6
# GITHUB_QUESTION_MAX_TOKENS=420
# GITHUB_EVAL_MAX_TOKENS=520
# GITHUB_FEEDBACK_MAX_TOKENS=420

# Default is strict LLM-first mode (no rule fallback)
ALLOW_RULE_BASED_FALLBACK=false

# --- Text-to-Speech (interviewer voice) ---
# ElevenLabs — best quality (free tier: 10k chars/mo)
# Get key at https://elevenlabs.io — key format: sk_...
ELEVENLABS_API_KEY=
# Optional: OpenAI TTS fallback (key format: sk-proj-...)
OPENAI_TTS_API_KEY=
# Voice alias: nova (default), alloy, echo, shimmer, onyx, fable, interviewer
TTS_VOICE=nova
